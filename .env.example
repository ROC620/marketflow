# ─── Variables d'environnement MarchéduRoi ───────────────────────────────────
# Copiez ce fichier en .env et remplacez les valeurs

# Supabase
VITE_SUPABASE_URL=https://VOTRE_PROJET.supabase.co
VITE_SUPABASE_ANON_KEY=VOTRE_CLE_ANON_SUPABASE

# FedaPay — paiement Bénin + zone UEMOA (9 pays)
# Sandbox : https://sandbox.fedapay.com
# Production : https://app.fedapay.com
VITE_FEDAPAY_PUBLIC_KEY=pk_sandbox_VOTRE_CLE_ICI

# Flutterwave — paiement panafricain (18 pays)
# Sandbox : https://dashboard.flutterwave.com/dashboard/settings/apis
# Production : remplacer FLWPUBK_TEST par FLWPUBK_LIVE
VITE_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-VOTRE_CLE_ICI-X
